@model IEnumerable<on_it_1.Models.Song>

@{
    ViewData["Title"] = "Nirvana Archive";
}

<style>
    body {
        background-color: #121212;
        color: #ffff00;
        font-family: 'Courier New', Courier, monospace;
    }

    .grunge-border {
        border: 2px solid #ffff00 !important;
    }

    .yellow-text {
        color: #ffff00 !important;
    }

    .table-grunge {
        width: 100%;
        margin-top: 20px;
        border-collapse: collapse;
    }

        .table-grunge th, .table-grunge td {
            padding: 12px;
            border-bottom: 1px solid #ffff00;
            text-align: left;
            color: #ffff00 !important;
        }

    .edit-input {
        background-color: #000;
        border: 1px solid #ffff00;
        color: #ffff00;
        width: 90%;
        padding: 5px;
    }

    .btn-grunge {
        background-color: #ffff00;
        color: #000;
        border: none;
        padding: 5px 15px;
        font-weight: bold;
        cursor: pointer;
        text-transform: uppercase;
        display: inline-block;
        text-decoration: none;
    }

    .btn-outline {
        background: transparent;
        border: 1px solid #ffff00;
        color: #ffff00;
    }

    .btn-danger-grunge {
        background-color: #ff0000;
        color: #fff;
    }

    .btn-grunge:hover {
        background-color: #fff;
        color: #000;
    }

    .d-none {
        display: none;
    }
</style>

<div class="container" style="padding: 40px;">
    <h1 style="text-align: center; text-transform: uppercase; border-bottom: 4px solid #ffff00; padding-bottom: 10px;">
        Nirvana Song Database
    </h1>

    @* Блок поиска *@
    <div style="margin: 30px 0;">
        <form asp-action="Index" method="get" style="display: flex; gap: 10px;">
            <input type="text" name="searchString" class="edit-input" style="flex-grow: 1;" placeholder="Search" />
            <button type="submit" class="btn-grunge">Search</button>
            <a asp-action="Index" class="btn-grunge btn-outline">Show All</a>
        </form>
    </div>

    @* Форма создания нового трека *@
    <div class="grunge-border" style="padding: 20px; background: #1a1a1a; margin-bottom: 40px;">
        <h3 class="yellow-text">ADD NEW TRACK</h3>
        <form asp-action="Create" method="post" style="display: grid; grid-template-columns: repeat(5, 1fr); gap: 10px;">
            <input type="text" name="Title" class="edit-input" placeholder="Title" required />
            <input type="text" name="Album" class="edit-input" placeholder="Album" required />
            <select name="Year" class="edit-input" required>
                <option value="" disabled selected>Year</option>
                @for (int y = DateTime.Now.Year; y >= 1989; y--)
                {
                    <option value="@y">@y</option>
                }
            </select>
            <input type="text" name="Tuning" class="edit-input" placeholder="Tuning" required />
            <button type="submit" class="btn-grunge">Save</button>
        </form>
    </div>

    @* Таблица со списком песен *@
    <table class="table-grunge">
        <thead>
            <tr>
                <th>TITLE</th>
                <th>ALBUM</th>
                <th>YEAR</th>
                <th>TUNING</th>
                <th style="width: 250px;">ACTIONS</th>
            </tr>
        </thead>
        <tbody>
            @foreach (var item in Model)
            {
                <tr id="row-@item.Id">
                    <td>
                        <span class="view-@item.Id">@item.Title</span>
                        <input type="text" form="edit-form-@item.Id" name="Title" value="@item.Title" class="edit-@item.Id d-none edit-input" required />
                    </td>
                    <td>
                        <span class="view-@item.Id">@item.Album</span>
                        <input type="text" form="edit-form-@item.Id" name="Album" value="@item.Album" class="edit-@item.Id d-none edit-input" required />
                    </td>
                    <td>
                        <span class="view-@item.Id">@item.Year</span>
                        <input type="number" form="edit-form-@item.Id" name="Year" value="@item.Year" class="edit-@item.Id d-none edit-input" required />
                    </td>
                    <td>
                        <span class="view-@item.Id">@item.Tuning</span>
                        <input type="text" form="edit-form-@item.Id" name="Tuning" value="@item.Tuning" class="edit-@item.Id d-none edit-input" required />
                    </td>
                    <td>
                        <div style="display: flex; gap: 10px; align-items: center;">
                            @* Форма редактирования скрыта, но привязана к инпутам через атрибут form *@
                            <form asp-action="Edit" method="post" id="edit-form-@item.Id" style="display:none;">
                                <input type="hidden" name="Id" value="@item.Id" />
                            </form>

                            <button type="button" id="btn-edit-@item.Id" class="btn-grunge btn-outline" onclick="toggleEdit('@item.Id')">Edit</button>
                            <button type="submit" form="edit-form-@item.Id" id="btn-save-@item.Id" class="btn-grunge d-none">Save</button>

                            @* Форма удаления — абсолютно независимая *@
                            <form asp-action="Delete" asp-route-id="@item.Id" method="post" onsubmit="return confirm('DESTROY THIS TRACK?');">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn-grunge btn-danger-grunge">Delete</button>
                            </form>
                        </div>
                    </td>
                </tr>
            }
        </tbody>
    </table>
</div>

<script>
    function toggleEdit(id) {
        // Переключаем видимость текста и инпутов
        document.querySelectorAll('.view-' + id).forEach(el => el.classList.toggle('d-none'));
        document.querySelectorAll('.edit-' + id).forEach(el => el.classList.toggle('d-none'));

        // Переключаем кнопки Edit/Save
        document.getElementById('btn-edit-' + id).classList.toggle('d-none');
        document.getElementById('btn-save-' + id).classList.toggle('d-none');
    }
</script>